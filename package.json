{
  "private": true,
  "scripts": {
    "check:frontend": "tsc --noEmit -p tsconfig.json",
    "validate": "npm run check:frontend",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "build:prod": "vite build --config frontend/vite.config.ts --mode production",
    "preview": "vite preview --config frontend/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chartgpu": "^0.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@solidjs/router": "^0.15.4",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.4",
    "apache-arrow": "^16.1.0",
    "babel-preset-solid": "^1.9.12",
    "echarts": "^5.6.0",
    "esbuild": "^0.25.0",
    "happy-dom": "^20.9.0",
    "solid-js": "^1.9.12",
    "typescript": "^5.8.0",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^2.0.4"
  }
}
